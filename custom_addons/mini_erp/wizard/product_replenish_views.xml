<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_replenish_wizard_form" model="ir.ui.view">
            <field name="name">product.replenish.wizard.form</field>
            <field name="model">product.replenish.wizard</field>
            <field name="arch" type="xml">
                <form string="Replenish Product">
                    <group>
                        <field name="product_id" readonly="1"/>
                        <field name="replenish_type"/>
                        <field name="quantity"/>
                    </group>
                    <footer>
                        <button name="action_replenish" string="Confirm" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_product_replenish_wizard" model="ir.actions.act_window">
            <field name="name">Product Replenishment</field>
            <field name="res_model">product.replenish.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
