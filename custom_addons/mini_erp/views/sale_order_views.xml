<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List/Tree View -->
        <record id="view_sale_order_tree" model="ir.ui.view">
            <field name="name">sale.order.tree</field>
            <field name="model">sale.order</field>
            <field name="arch" type="xml">
                <list string="Sales Orders" decoration-info="state == 'draft'" decoration-success="state == 'fully_delivered'">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="date_order"/>
                    <field name="user_id"/>
                    <field name="total_amount" widget="monetary"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'draft'"
                           decoration-warning="state in ('confirmed', 'partially_delivered')"
                           decoration-success="state == 'fully_delivered'"
                           decoration-danger="state == 'cancelled'"/>
                    <field name="currency_id" column_invisible="True"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_sale_order_form" model="ir.ui.view">
            <field name="name">sale.order.form</field>
            <field name="model">sale.order</field>
            <field name="arch" type="xml">
                <form string="Sales Order">
                    <header>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_deliver" string="Deliver" type="object" class="btn-primary" invisible="state not in ('confirmed', 'partially_delivered')"/>
                        <button name="action_cancel" string="Cancel" type="object" class="btn-secondary" invisible="state not in ('draft', 'confirmed')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,partially_delivered,fully_delivered,cancelled"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_audit_logs" type="object" class="oe_stat_button" icon="fa-history">
                                <span class="o_stat_text">Logs</span>
                            </button>
                            <button name="action_view_deliveries" type="object" class="oe_stat_button" icon="fa-truck">
                                <field name="delivery_count" string="Deliveries" widget="statinfo"/>
                            </button>
                            <button name="action_view_mrp_productions" type="object" class="oe_stat_button" icon="fa-wrench">
                                <field name="mrp_production_count" string="Manufacturing" widget="statinfo"/>
                            </button>
                            <button name="action_view_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                                <field name="purchase_order_count" string="Purchases" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="partner_id" readonly="state != 'draft'"/>
                                <field name="partner_address" placeholder="Auto-filled from partner, editable" readonly="state not in ('draft', 'confirmed')"/>
                                <field name="date_order" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="user_id" readonly="state != 'draft'"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="total_amount" widget="monetary"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Order Lines" name="order_lines">
                                <field name="order_line_ids" readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="description"/>
                                        <field name="quantity"/>
                                        <field name="delivered_qty" readonly="1"/>
                                        <field name="reserved_qty" readonly="1"/>
                                        <field name="price_unit"/>
                                        <field name="subtotal" sum="Total" widget="monetary"/>
                                        <field name="stock_availability"/>
                                        <field name="currency_id" column_invisible="True"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Delivery Status" name="delivery_status">
                                <group>
                                    <field name="state" readonly="1" string="Current Delivery State"/>
                                </group>
                            </page>
                            <page string="Notes" name="notes">
                                <field name="notes" placeholder="Enter terms, conditions, or internal notes here..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_sale_order_kanban" model="ir.ui.view">
            <field name="name">sale.order.kanban</field>
            <field name="model">sale.order</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" quick_create="false">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="total_amount"/>
                    <field name="state"/>
                    <field name="currency_id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_record_body">
                                        <div>Customer: <field name="partner_id"/></div>
                                        <div>Total: <field name="total_amount" widget="monetary"/></div>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <span class="float-end">
                                            <field name="state" widget="label_selection"
                                                   options="{'classes': {'draft': 'info', 'confirmed': 'warning', 'partially_delivered': 'warning', 'fully_delivered': 'success', 'cancelled': 'danger'}}"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_sale_order_search" model="ir.ui.view">
            <field name="name">sale.order.search</field>
            <field name="model">sale.order</field>
            <field name="arch" type="xml">
                <search string="Search Sales Orders">
                    <field name="name" string="Order Number"/>
                    <field name="partner_id" string="Customer"/>
                    <field name="user_id" string="Salesperson"/>
                    <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter name="filter_partially_delivered" string="Partially Delivered" domain="[('state', '=', 'partially_delivered')]"/>
                    <filter name="filter_fully_delivered" string="Fully Delivered" domain="[('state', '=', 'fully_delivered')]"/>
                    <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                    <separator/>
                    <filter name="group_by_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_date" string="Order Date" context="{'group_by': 'date_order'}"/>
                </search>
            </field>
        </record>

        <!-- Window Action -->
        <record id="action_sale_orders" model="ir.actions.act_window">
            <field name="name">Sales Orders</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="search_view_id" ref="view_sale_order_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Sales Order.
                </p>
            </field>
        </record>

        <!-- Root Menu definition -->
        <menuitem id="menu_mini_erp_root" name="Mini ERP" sequence="5"/>

        <!-- Sales Menu Category -->
        <menuitem id="menu_sales_category" name="Sales" parent="menu_mini_erp_root" sequence="10"/>
        <menuitem id="menu_sale_orders" name="Sales Orders" parent="menu_sales_category" action="action_sale_orders" sequence="10"/>
        <menuitem id="menu_sale_customers" name="Customers" parent="menu_sales_category" action="action_partner_customers" sequence="20"/>
    </data>
</odoo>
