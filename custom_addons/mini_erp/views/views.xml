<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Window Actions -->
        <record id="action_product_product" model="ir.actions.act_window">
            <field name="name">Products</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="view_product_product_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first product!
                </p>
            </field>
        </record>

        <!-- Product Category Kanban View -->
        <record id="view_product_category_kanban" model="ir.ui.view">
            <field name="name">product.category.kanban</field>
            <field name="model">product.category</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="complete_name"/>
                    <field name="parent_id"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title"><field name="complete_name"/></strong>
                                    <t t-if="record.parent_id.raw_value">
                                        <div class="text-muted small mt-1">Parent: <field name="parent_id"/></div>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Product UOM Kanban View -->
        <record id="view_product_uom_kanban" model="ir.ui.view">
            <field name="name">product.uom.kanban</field>
            <field name="model">product.uom</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="name"/>
                    <field name="code"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <div class="text-muted small mt-1">Code: <field name="code"/></div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_product_category" model="ir.actions.act_window">
            <field name="name">Product Categories</field>
            <field name="res_model">product.category</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Define product categories to organize your stock.
                </p>
            </field>
        </record>

        <record id="action_product_uom" model="ir.actions.act_window">
            <field name="name">Units of Measure</field>
            <field name="res_model">product.uom</field>
            <field name="view_mode">kanban,list,form</field>
        </record>

        <!-- Menu Hierarchy -->
        <menuitem id="menu_mini_erp_root"
                  name="Mini ERP"
                  sequence="10"/>

        <menuitem id="menu_products_parent"
                  name="Products"
                  parent="menu_mini_erp_root"
                  sequence="10"/>

        <menuitem id="menu_products_list"
                  name="Products"
                  parent="menu_products_parent"
                  action="action_product_product"
                  sequence="10"
                  groups="base.group_user"/>

        <menuitem id="menu_product_categories"
                  name="Categories"
                  parent="menu_products_parent"
                  action="action_product_category"
                  sequence="20"
                  groups="base.group_user"/>

        <menuitem id="menu_product_uom"
                  name="Units of Measure"
                  parent="menu_products_parent"
                  action="action_product_uom"
                  sequence="30"
                  groups="base.group_user"/>
    </data>
</odoo>
