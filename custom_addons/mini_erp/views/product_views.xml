<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_uom_tree" model="ir.ui.view">
            <field name="name">product.uom.tree</field>
            <field name="model">product.uom</field>
            <field name="arch" type="xml">
                <list string="Units of Measure" multi_edit="0">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_product_uom_form" model="ir.ui.view">
            <field name="name">product.uom.form</field>
            <field name="model">product.uom</field>
            <field name="arch" type="xml">
                <form string="Unit of Measure">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_product_category_tree" model="ir.ui.view">
            <field name="name">product.category.tree</field>
            <field name="model">product.category</field>
            <field name="arch" type="xml">
                <list string="Product Categories" multi_edit="0">
                    <field name="complete_name"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_product_category_form" model="ir.ui.view">
            <field name="name">product.category.form</field>
            <field name="model">product.category</field>
            <field name="arch" type="xml">
                <form string="Product Category">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="parent_id"/>
                            <field name="description"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_product_product_tree" model="ir.ui.view">
            <field name="name">product.product.tree</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <list string="Products" multi_edit="0" default_order="name">
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="category_id" optional="show"/>
                    <field name="product_type" optional="show"/>
                    <field name="sale_price" widget="monetary"/>
                    <field name="cost_price" widget="monetary"/>
                    <field name="uom_id" optional="show"/>
                    <field name="on_hand_qty"/>
                    <field name="free_to_use_qty"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_product_product_kanban" model="ir.ui.view">
            <field name="name">product.product.kanban</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <kanban quick_create="false">
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="product_type"/>
                    <field name="sale_price"/>
                    <field name="on_hand_qty"/>
                    <field name="free_to_use_qty"/>
                    <field name="currency_id"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <div class="text-muted small">
                                        Ref: <field name="reference"/>
                                    </div>
                                    <div class="mt-2 text-muted small">
                                        Type: <field name="product_type"/>
                                    </div>
                                    <div class="mt-2 d-flex justify-content-between align-items-center">
                                        <span class="font-weight-bold text-success"><field name="sale_price" widget="monetary"/></span>
                                        <span class="badge text-bg-info">Stock: <field name="on_hand_qty"/></span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_product_product_form" model="ir.ui.view">
            <field name="name">product.product.form</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <form string="Product">
                    <header>
                        <button name="action_open_replenish_wizard" string="Replenish" type="object" class="btn-primary" invisible="not id"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(action_open_audit_logs_product)d"
                                    type="action"
                                    string="Logs"
                                    class="oe_stat_button"
                                    icon="fa-list"
                                    context="{'search_default_model_name': 'product.product'}"
                                    groups="mini_erp.group_admin"/>
                        </div>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="reference" readonly="1"/>
                                <field name="category_id"/>
                                <field name="product_type"/>
                                <field name="uom_id"/>
                            </group>
                            <group>
                                <field name="sale_price" widget="monetary"/>
                                <field name="cost_price" widget="monetary"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Inventory">
                                <group>
                                    <field name="on_hand_qty" readonly="1"/>
                                    <field name="reserved_qty" readonly="1"/>
                                    <field name="free_to_use_qty" readonly="1"/>
                                </group>
                            </page>
                            <page string="Procurement Settings">
                                <group>
                                    <group string="Configuration">
                                        <field name="procure_on_demand"/>
                                        <field name="procurement_type" invisible="not procure_on_demand"/>
                                    </group>
                                    <group string="Stock Parameters">
                                        <field name="min_stock_qty"/>
                                        <field name="lead_time_days"/>
                                    </group>
                                </group>
                                <group invisible="not procure_on_demand">
                                    <group string="Purchase Details" invisible="procurement_type != 'purchase'">
                                        <field name="vendor_id" required="procure_on_demand and procurement_type == 'purchase'"/>
                                    </group>
                                    <group string="Manufacturing Details" invisible="procurement_type != 'manufacture'">
                                        <field name="bom_id" required="procure_on_demand and procurement_type == 'manufacture'"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_product_product_search" model="ir.ui.view">
            <field name="name">product.product.search</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="category_id"/>
                    <filter name="filter_stockable" string="Stockable"
                            domain="[('product_type', '=', 'stockable')]"/>
                    <filter name="filter_service" string="Service"
                            domain="[('product_type', '=', 'service')]"/>
                    <filter name="filter_consumable" string="Consumable"
                            domain="[('product_type', '=', 'consumable')]"/>
                    <separator/>
                    <filter name="group_by_category" string="Category"
                            context="{'group_by': 'category_id'}"/>
                </search>
            </field>
        </record>

    </data>
</odoo>
