<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Stock Ledger Tree View -->
        <record id="view_stock_ledger_tree" model="ir.ui.view">
            <field name="name">stock.ledger.tree</field>
            <field name="model">stock.ledger</field>
            <field name="arch" type="xml">
                <list string="Stock Ledger" create="0" edit="0" delete="0" duplicate="0"
                      decoration-success="quantity &gt; 0"
                      decoration-danger="quantity &lt; 0">
                    <field name="date"/>
                    <field name="product_id"/>
                    <field name="reference"/>
                    <field name="transaction_type" widget="badge"
                           decoration-info="transaction_type in ('initial', 'adjustment')"
                           decoration-success="transaction_type in ('purchase_receipt', 'manufacture_in')"
                           decoration-warning="transaction_type in ('sale_delivery', 'manufacture_out')"/>
                    <field name="quantity" string="Quantity"/>
                    <field name="balance_after"/>
                    <field name="user_id"/>
                </list>
            </field>
        </record>

        <!-- Stock Ledger Search View -->
        <record id="view_stock_ledger_search" model="ir.ui.view">
            <field name="name">stock.ledger.search</field>
            <field name="model">stock.ledger</field>
            <field name="arch" type="xml">
                <search string="Search Stock Ledger">
                    <field name="product_id"/>
                    <field name="reference"/>
                    <field name="transaction_type"/>
                    <separator/>
                    <filter name="group_by_product" string="Product" context="{'group_by': 'product_id'}"/>
                    <filter name="group_by_type" string="Transaction Type" context="{'group_by': 'transaction_type'}"/>
                </search>
            </field>
        </record>

        <!-- Window Action -->
        <record id="action_stock_ledger" model="ir.actions.act_window">
            <field name="name">Stock Ledger</field>
            <field name="res_model">stock.ledger</field>
            <field name="view_mode">list</field>
            <field name="search_view_id" ref="view_stock_ledger_search"/>
            <field name="help" type="html">
                <p>
                    Stock Ledger tracks every inventory movement (incoming and outgoing) in the system.
                </p>
            </field>
        </record>

        <!-- Menu Item under Products parent -->
        <menuitem id="menu_stock_ledger"
                  name="Stock Ledger"
                  parent="menu_products_parent"
                  action="action_stock_ledger"
                  sequence="30"
                  groups="mini_erp.group_admin,mini_erp.group_inventory_manager"/>
    </data>
</odoo>
