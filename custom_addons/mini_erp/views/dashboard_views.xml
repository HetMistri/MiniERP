<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_dashboard_data_form" model="ir.ui.view">
            <field name="name">dashboard.data.form</field>
            <field name="model">dashboard.data</field>
            <field name="arch" type="xml">
                <form string="Dashboard" create="false" edit="true" delete="false" class="o_mini_erp_dashboard_form">
                    <sheet>
                        <div class="o_dashboard_container">
                            <!-- Sidebar: Master Menu -->
                            <div class="o_dashboard_sidebar">
                                <div class="o_sidebar_brand">
                                    <i class="fa fa-cubes fa-2x brand-icon" title="Logo"/>
                                    <span class="brand-text">Mini ERP</span>
                                </div>
                                <div class="o_sidebar_menu mt-4">
                                    <button name="action_view_sales" type="object" class="o_sidebar_link">
                                        <i class="fa fa-shopping-cart mr-2" title="Sales"/>Sales Orders
                                    </button>
                                    <button name="action_view_products" type="object" class="o_sidebar_link">
                                        <i class="fa fa-barcode mr-2" title="Products"/>Products
                                    </button>
                                    <button name="action_view_mos" type="object" class="o_sidebar_link">
                                        <i class="fa fa-wrench mr-2" title="Manufacturing"/>Manufacturing Orders
                                    </button>
                                    <button name="action_view_pos" type="object" class="o_sidebar_link">
                                        <i class="fa fa-credit-card mr-2" title="Purchase"/>Purchase Orders
                                    </button>
                                    <button name="action_view_boms" type="object" class="o_sidebar_link">
                                        <i class="fa fa-list-alt mr-2" title="BOM"/>Bills of Materials
                                    </button>
                                </div>
                            </div>

                            <!-- Main Dashboard Area -->
                            <div class="o_dashboard_main">
                                <!-- Top Bar & Search -->
                                <div class="o_dashboard_topbar d-flex align-items-center justify-content-between mb-4">
                                    <div class="o_topbar_title">
                                        <h1 class="text-gradient mb-0">Operations Dashboard</h1>
                                        <p class="text-muted mb-0 small">Real-time status overview &amp; tracking</p>
                                    </div>
                                    <div class="o_topbar_search d-flex align-items-center">
                                        <field name="search_query" placeholder="Global Search (SO, PO, MO, Product)..." class="o_search_input mr-2"/>
                                        <button name="action_search" type="object" class="btn btn-primary btn-search mr-1">
                                            <i class="fa fa-search" title="Search"/>
                                        </button>
                                        <button name="action_clear_search" type="object" class="btn btn-secondary btn-clear" invisible="not search_query">
                                            <i class="fa fa-times" title="Clear"/>
                                        </button>
                                    </div>
                                </div>

                                <!-- Global KPI Cards (Low Stock & Delayed) -->
                                <div class="row mb-4">
                                    <div class="col-12 col-md-6 mb-3">
                                        <div class="card o_dashboard_card card-lowstock text-center shadow-sm">
                                            <div class="card-body">
                                                <div class="o_card_icon"><i class="fa fa-archive fa-2x text-danger" title="Low Stock"/></div>
                                                <div class="text-uppercase text-muted small font-weight-bold mt-2">Low Stock Items</div>
                                                <div class="h2 font-weight-bold text-danger my-2">
                                                    <field name="low_stock_products"/>
                                                </div>
                                                <button name="action_view_low_stock" type="object" string="Replenish Now" class="btn btn-sm btn-danger mt-2 w-100"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-6 mb-3">
                                        <div class="card o_dashboard_card card-delayed text-center shadow-sm">
                                            <div class="card-body">
                                                <div class="o_card_icon"><i class="fa fa-exclamation-triangle fa-2x text-danger" title="Delayed"/></div>
                                                <div class="text-uppercase text-muted small font-weight-bold mt-2">Delayed Orders</div>
                                                <div class="h2 font-weight-bold text-danger my-2">
                                                    <field name="delayed_orders"/>
                                                </div>
                                                <button name="action_view_delayed_orders" type="object" string="View Delayed" class="btn btn-sm btn-danger mt-2 w-100"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Search Results Panel -->
                                <div class="o_search_results mt-4 mb-4" invisible="not search_query">
                                    <h3 class="text-primary mb-3"><i class="fa fa-search mr-2" title="Search Results"/>Search Results</h3>
                                    <div class="row">
                                        <div class="col-12 col-md-6 mb-3" invisible="not search_sale_ids">
                                            <h5 class="text-muted">Sales Orders</h5>
                                            <field name="search_sale_ids" readonly="1">
                                                <list create="false" edit="false" delete="false">
                                                    <field name="name" string="Reference"/>
                                                    <field name="partner_id" string="Customer"/>
                                                    <field name="state" string="State"/>
                                                </list>
                                            </field>
                                        </div>
                                        <div class="col-12 col-md-6 mb-3" invisible="not search_product_ids">
                                            <h5 class="text-muted">Products</h5>
                                            <field name="search_product_ids" readonly="1">
                                                <list create="false" edit="false" delete="false">
                                                    <field name="name" string="Product"/>
                                                    <field name="reference" string="Ref"/>
                                                    <field name="free_to_use_qty" string="Free Stock"/>
                                                </list>
                                            </field>
                                        </div>
                                        <div class="col-12 col-md-6 mb-3" invisible="not search_purchase_ids">
                                            <h5 class="text-muted">Purchase Orders</h5>
                                            <field name="search_purchase_ids" readonly="1">
                                                <list create="false" edit="false" delete="false">
                                                    <field name="name" string="Reference"/>
                                                    <field name="partner_id" string="Vendor"/>
                                                    <field name="state" string="State"/>
                                                </list>
                                            </field>
                                        </div>
                                        <div class="col-12 col-md-6 mb-3" invisible="not search_mo_ids">
                                            <h5 class="text-muted">Manufacturing Orders</h5>
                                            <field name="search_mo_ids" readonly="1">
                                                <list create="false" edit="false" delete="false">
                                                    <field name="name" string="Reference"/>
                                                    <field name="product_id" string="Product"/>
                                                    <field name="state" string="State"/>
                                                </list>
                                            </field>
                                        </div>
                                    </div>
                                </div>

                                <!-- Sales Section -->
                                <div class="o_section_box mb-4">
                                    <div class="o_section_header d-flex justify-content-between align-items-center mb-3">
                                        <h3 class="section-title text-primary"><i class="fa fa-shopping-cart mr-2" title="Sales Section"/>Sales Orders</h3>
                                        <div class="o_my_filter_toggle d-flex align-items-center">
                                            <span class="mr-2 text-muted small">My Sales Only</span>
                                            <field name="filter_my_sales" widget="boolean_toggle"/>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col">
                                            <div class="o_kpi_card_row d-flex flex-wrap justify-content-between">
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">All</span>
                                                    <span class="h4 font-weight-bold text-dark"><field name="so_all"/></span>
                                                    <button name="action_view_sales" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Draft</span>
                                                    <span class="h4 font-weight-bold text-warning"><field name="so_draft"/></span>
                                                    <button name="action_view_so_draft" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Confirmed</span>
                                                    <span class="h4 font-weight-bold text-primary"><field name="so_confirmed"/></span>
                                                    <button name="action_view_so_confirmed" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Partially Del.</span>
                                                    <span class="h4 font-weight-bold text-info"><field name="so_partial"/></span>
                                                    <button name="action_view_so_partial" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Delivered</span>
                                                    <span class="h4 font-weight-bold text-success"><field name="so_delivered"/></span>
                                                    <button name="action_view_so_delivered" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Purchase Section -->
                                <div class="o_section_box mb-4">
                                    <div class="o_section_header d-flex justify-content-between align-items-center mb-3">
                                        <h3 class="section-title text-indigo"><i class="fa fa-credit-card mr-2" title="Purchase Section"/>Purchase Orders</h3>
                                        <div class="o_my_filter_toggle d-flex align-items-center">
                                            <span class="mr-2 text-muted small">My Purchases Only</span>
                                            <field name="filter_my_purchases" widget="boolean_toggle"/>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col">
                                            <div class="o_kpi_card_row d-flex flex-wrap justify-content-between">
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">All</span>
                                                    <span class="h4 font-weight-bold text-dark"><field name="po_all"/></span>
                                                    <button name="action_view_pos" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Draft</span>
                                                    <span class="h4 font-weight-bold text-warning"><field name="po_draft"/></span>
                                                    <button name="action_view_po_draft" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Confirmed</span>
                                                    <span class="h4 font-weight-bold text-primary"><field name="po_confirmed"/></span>
                                                    <button name="action_view_po_confirmed" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Partially Rec.</span>
                                                    <span class="h4 font-weight-bold text-info"><field name="po_partial"/></span>
                                                    <button name="action_view_po_partial" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Received</span>
                                                    <span class="h4 font-weight-bold text-success"><field name="po_received"/></span>
                                                    <button name="action_view_po_received" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Late</span>
                                                    <span class="h4 font-weight-bold text-danger"><field name="po_late"/></span>
                                                    <button name="action_view_po_late" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Manufacturing Section -->
                                <div class="o_section_box mb-4">
                                    <div class="o_section_header d-flex justify-content-between align-items-center mb-3">
                                        <h3 class="section-title text-info"><i class="fa fa-wrench mr-2" title="Mfg Section"/>Manufacturing Orders</h3>
                                        <div class="o_my_filter_toggle d-flex align-items-center">
                                            <span class="mr-2 text-muted small">My MOs Only</span>
                                            <field name="filter_my_manufacturing" widget="boolean_toggle"/>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col">
                                            <div class="o_kpi_card_row d-flex flex-wrap justify-content-between">
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">All</span>
                                                    <span class="h4 font-weight-bold text-dark"><field name="mo_all"/></span>
                                                    <button name="action_view_mos" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Draft</span>
                                                    <span class="h4 font-weight-bold text-warning"><field name="mo_draft"/></span>
                                                    <button name="action_view_mo_draft" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Confirmed</span>
                                                    <span class="h4 font-weight-bold text-primary"><field name="mo_confirmed"/></span>
                                                    <button name="action_view_mo_confirmed" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">In Progress</span>
                                                    <span class="h4 font-weight-bold text-info"><field name="mo_progress"/></span>
                                                    <button name="action_view_mo_progress" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">To Close</span>
                                                    <span class="h4 font-weight-bold text-danger"><field name="mo_to_close"/></span>
                                                    <button name="action_view_mo_to_close" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                                <div class="o_kpi_subcard flex-fill mx-1 mb-2 text-center">
                                                    <span class="text-muted small d-block">Done</span>
                                                    <span class="h4 font-weight-bold text-success"><field name="mo_done"/></span>
                                                    <button name="action_view_mo_done" type="object" class="o_card_overlay_btn"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Audit Log Section -->
                                <div class="o_audit_section mt-5" groups="mini_erp.group_admin">
                                    <h3 class="border-bottom pb-2 text-primary"><i class="fa fa-history mr-2" title="Audit History"/>Recent Audit Logs</h3>
                                    <field name="recent_audit_log_ids" readonly="1">
                                        <list>
                                            <field name="timestamp" string="Time"/>
                                            <field name="user_id" string="User"/>
                                            <field name="action" string="Action"/>
                                            <field name="model_name" string="Model"/>
                                            <field name="record_id" string="ID"/>
                                            <field name="display_name" string="Summary"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Server Action to open the dashboard transient record -->
        <record id="action_server_dashboard" model="ir.actions.server">
            <field name="name">Dashboard</field>
            <field name="model_id" ref="model_dashboard_data"/>
            <field name="state">code</field>
            <field name="code">action = model.action_open_dashboard()</field>
        </record>

        <!-- Top-level Menu Item (first position) -->
        <menuitem id="menu_mini_erp_dashboard" name="Dashboard" parent="menu_mini_erp_root" action="action_server_dashboard" sequence="1"/>
    </data>
</odoo>
