<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Unit of Measures -->
        <record id="uom_pcs" model="product.uom">
            <field name="name">Pieces</field>
            <field name="code">Pcs</field>
        </record>
        <record id="uom_kg" model="product.uom">
            <field name="name">Kilogram</field>
            <field name="code">Kg</field>
        </record>
        <record id="uom_m" model="product.uom">
            <field name="name">Meters</field>
            <field name="code">M</field>
        </record>
        <record id="uom_hr" model="product.uom">
            <field name="name">Hours</field>
            <field name="code">Hr</field>
        </record>

        <!-- Categories -->
        <record id="cat_finished_goods" model="product.category">
            <field name="name">Finished Goods</field>
        </record>
        <record id="cat_raw_materials" model="product.category">
            <field name="name">Raw Materials</field>
        </record>
        <record id="cat_tables" model="product.category">
            <field name="name">Tables</field>
            <field name="parent_id" ref="cat_finished_goods"/>
        </record>
        <record id="cat_chairs" model="product.category">
            <field name="name">Chairs</field>
            <field name="parent_id" ref="cat_finished_goods"/>
        </record>

        <!-- Products -->
        <record id="product_wooden_table" model="product.product">
            <field name="name">Wooden Table</field>
            <field name="category_id" ref="cat_tables"/>
            <field name="sale_price">15000.00</field>
            <field name="cost_price">8500.00</field>
            <field name="uom_id" ref="uom_pcs"/>
            <field name="product_type">stockable</field>
        </record>

        <record id="product_office_chair" model="product.product">
            <field name="name">Office Chair</field>
            <field name="category_id" ref="cat_chairs"/>
            <field name="sale_price">8000.00</field>
            <field name="cost_price">4500.00</field>
            <field name="uom_id" ref="uom_pcs"/>
            <field name="product_type">stockable</field>
        </record>

        <record id="product_dining_table" model="product.product">
            <field name="name">Dining Table</field>
            <field name="category_id" ref="cat_tables"/>
            <field name="sale_price">25000.00</field>
            <field name="cost_price">14000.00</field>
            <field name="uom_id" ref="uom_pcs"/>
            <field name="product_type">stockable</field>
        </record>

        <record id="product_wooden_legs" model="product.product">
            <field name="name">Wooden Legs</field>
            <field name="category_id" ref="cat_raw_materials"/>
            <field name="sale_price">500.00</field>
            <field name="cost_price">200.00</field>
            <field name="uom_id" ref="uom_pcs"/>
            <field name="product_type">stockable</field>
        </record>

        <record id="product_screws" model="product.product">
            <field name="name">Screws</field>
            <field name="category_id" ref="cat_raw_materials"/>
            <field name="sale_price">10.00</field>
            <field name="cost_price">2.00</field>
            <field name="uom_id" ref="uom_pcs"/>
            <field name="product_type">consumable</field>
        </record>

        <!-- Demo Partners (Customers) -->
        <record id="partner_suzuki_india" model="res.partner">
            <field name="name">Suzuki India</field>
            <field name="is_customer" eval="True"/>
            <field name="is_vendor" eval="False"/>
            <field name="partner_type">company</field>
            <field name="email">procurement@suzuki-india.com</field>
            <field name="phone">+91 98765 43210</field>
        </record>

        <record id="partner_mrf_ltd" model="res.partner">
            <field name="name">MRF Ltd</field>
            <field name="is_customer" eval="True"/>
            <field name="is_vendor" eval="False"/>
            <field name="partner_type">company</field>
            <field name="email">orders@mrf.com</field>
            <field name="phone">+91 87654 32109</field>
        </record>

        <!-- Demo Partners (Vendors) -->
        <record id="partner_plastofact_in" model="res.partner">
            <field name="name">Plastofact IN</field>
            <field name="is_customer" eval="False"/>
            <field name="is_vendor" eval="True"/>
            <field name="partner_type">company</field>
            <field name="email">supply@plastofact.in</field>
            <field name="phone">+91 76543 21098</field>
        </record>

        <record id="partner_orm_metals" model="res.partner">
            <field name="name">ORM Metals</field>
            <field name="is_customer" eval="False"/>
            <field name="is_vendor" eval="True"/>
            <field name="partner_type">company</field>
            <field name="email">sales@ormmetals.com</field>
            <field name="phone">+91 65432 10987</field>
        </record>

        <!-- Demo Sales Order 1 (Draft) -->
        <record id="so_draft_1" model="sale.order">
            <field name="partner_id" ref="partner_suzuki_india"/>
            <field name="state">draft</field>
            <field name="date_order" eval="datetime.now().strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <record id="so_line_draft_1" model="sale.order.line">
            <field name="order_id" ref="so_draft_1"/>
            <field name="product_id" ref="product_wooden_table"/>
            <field name="description">Wooden Table</field>
            <field name="quantity">2.0</field>
            <field name="price_unit">15000.00</field>
        </record>

        <!-- Demo Sales Order 2 (Confirmed) -->
        <record id="so_confirmed_1" model="sale.order">
            <field name="partner_id" ref="partner_mrf_ltd"/>
            <field name="state">draft</field>
            <field name="date_order" eval="(datetime.now() - timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <record id="so_line_confirmed_1" model="sale.order.line">
            <field name="order_id" ref="so_confirmed_1"/>
            <field name="product_id" ref="product_office_chair"/>
            <field name="description">Office Chair</field>
            <field name="quantity">5.0</field>
            <field name="price_unit">8000.00</field>
        </record>

        <!-- Execute action_confirm on Confirmed SO -->
        <function model="sale.order" name="action_confirm" eval="[[ref('so_confirmed_1')]]"/>

        <!-- Demo Purchase Order 1 (Draft) -->
        <record id="po_draft_1" model="purchase.order">
            <field name="partner_id" ref="partner_plastofact_in"/>
            <field name="state">draft</field>
            <field name="date_order" eval="datetime.now().strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <record id="po_line_draft_1" model="purchase.order.line">
            <field name="order_id" ref="po_draft_1"/>
            <field name="product_id" ref="product_wooden_legs"/>
            <field name="description">Wooden Legs</field>
            <field name="quantity">50.0</field>
            <field name="price_unit">200.00</field>
        </record>

        <!-- Demo Purchase Order 2 (Confirmed) -->
        <record id="po_confirmed_1" model="purchase.order">
            <field name="partner_id" ref="partner_orm_metals"/>
            <field name="state">draft</field>
            <field name="date_order" eval="(datetime.now() - timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <record id="po_line_confirmed_1" model="purchase.order.line">
            <field name="order_id" ref="po_confirmed_1"/>
            <field name="product_id" ref="product_screws"/>
            <field name="description">Screws</field>
            <field name="quantity">1000.0</field>
            <field name="price_unit">2.00</field>
        </record>

        <!-- Execute action_confirm on Confirmed PO -->
        <function model="purchase.order" name="action_confirm" eval="[[ref('po_confirmed_1')]]"/>

    </data>
</odoo>
