<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Demo Raw Material Products -->
        <record id="product_wooden_top" model="product.product">
            <field name="name">Wooden Top</field>
            <field name="category_id" ref="cat_raw_materials"/>
            <field name="sale_price">3000.00</field>
            <field name="cost_price">1500.00</field>
            <field name="uom_id" ref="uom_pcs"/>
            <field name="product_type">stockable</field>
        </record>

        <record id="product_chair_base" model="product.product">
            <field name="name">Chair Base</field>
            <field name="category_id" ref="cat_raw_materials"/>
            <field name="sale_price">1500.00</field>
            <field name="cost_price">800.00</field>
            <field name="uom_id" ref="uom_pcs"/>
            <field name="product_type">stockable</field>
        </record>

        <record id="product_wheels" model="product.product">
            <field name="name">Wheels</field>
            <field name="category_id" ref="cat_raw_materials"/>
            <field name="sale_price">200.00</field>
            <field name="cost_price">80.00</field>
            <field name="uom_id" ref="uom_pcs"/>
            <field name="product_type">stockable</field>
        </record>

        <!-- Initial Stock Ledger Entries for Raw Materials -->
        <record id="ledger_init_wooden_legs" model="stock.ledger">
            <field name="product_id" ref="product_wooden_legs"/>
            <field name="reference">INIT001</field>
            <field name="transaction_type">initial</field>
            <field name="quantity">100.0</field>
            <field name="balance_after">100.0</field>
        </record>

        <record id="ledger_init_wooden_top" model="stock.ledger">
            <field name="product_id" ref="product_wooden_top"/>
            <field name="reference">INIT002</field>
            <field name="transaction_type">initial</field>
            <field name="quantity">50.0</field>
            <field name="balance_after">50.0</field>
        </record>

        <record id="ledger_init_screws" model="stock.ledger">
            <field name="product_id" ref="product_screws"/>
            <field name="reference">INIT003</field>
            <field name="transaction_type">initial</field>
            <field name="quantity">1000.0</field>
            <field name="balance_after">1000.0</field>
        </record>

        <record id="ledger_init_chair_base" model="stock.ledger">
            <field name="product_id" ref="product_chair_base"/>
            <field name="reference">INIT004</field>
            <field name="transaction_type">initial</field>
            <field name="quantity">50.0</field>
            <field name="balance_after">50.0</field>
        </record>

        <record id="ledger_init_wheels" model="stock.ledger">
            <field name="product_id" ref="product_wheels"/>
            <field name="reference">INIT005</field>
            <field name="transaction_type">initial</field>
            <field name="quantity">250.0</field>
            <field name="balance_after">250.0</field>
        </record>

        <!-- Work Centers -->
        <record id="wc_assembly" model="mrp.work.center">
            <field name="name">Assembly Line</field>
            <field name="code">WC001</field>
            <field name="working_hours">8.0</field>
            <field name="cost_per_hour">500.00</field>
            <field name="description">Manual and automated parts assembly</field>
        </record>

        <record id="wc_paint" model="mrp.work.center">
            <field name="name">Paint Floor</field>
            <field name="code">WC002</field>
            <field name="working_hours">8.0</field>
            <field name="cost_per_hour">800.00</field>
            <field name="description">Sanding, prime coating, and painting</field>
        </record>

        <record id="wc_packaging" model="mrp.work.center">
            <field name="name">Packaging Unit</field>
            <field name="code">WC003</field>
            <field name="working_hours">8.0</field>
            <field name="cost_per_hour">300.00</field>
            <field name="description">Quality control, cleaning, boxing, and labelling</field>
        </record>

        <!-- BoM for Wooden Table -->
        <record id="bom_wooden_table" model="mrp.bom">
            <field name="product_id" ref="product_wooden_table"/>
            <field name="product_qty">1.0</field>
            <field name="notes">Standard solid wood dining table</field>
        </record>

        <!-- Components for Wooden Table BoM -->
        <record id="bom_comp_table_legs" model="mrp.bom.component">
            <field name="bom_id" ref="bom_wooden_table"/>
            <field name="product_id" ref="product_wooden_legs"/>
            <field name="quantity">4.0</field>
        </record>

        <record id="bom_comp_table_top" model="mrp.bom.component">
            <field name="bom_id" ref="bom_wooden_table"/>
            <field name="product_id" ref="product_wooden_top"/>
            <field name="quantity">1.0</field>
        </record>

        <record id="bom_comp_table_screws" model="mrp.bom.component">
            <field name="bom_id" ref="bom_wooden_table"/>
            <field name="product_id" ref="product_screws"/>
            <field name="quantity">12.0</field>
        </record>

        <!-- Operations for Wooden Table BoM -->
        <record id="bom_op_table_assembly" model="mrp.bom.operation">
            <field name="bom_id" ref="bom_wooden_table"/>
            <field name="work_center_id" ref="wc_assembly"/>
            <field name="name">Table Assembly</field>
            <field name="sequence">10</field>
            <field name="duration_minutes">60.0</field>
        </record>

        <record id="bom_op_table_painting" model="mrp.bom.operation">
            <field name="bom_id" ref="bom_wooden_table"/>
            <field name="work_center_id" ref="wc_paint"/>
            <field name="name">Table Painting</field>
            <field name="sequence">20</field>
            <field name="duration_minutes">30.0</field>
        </record>

        <record id="bom_op_table_packing" model="mrp.bom.operation">
            <field name="bom_id" ref="bom_wooden_table"/>
            <field name="work_center_id" ref="wc_packaging"/>
            <field name="name">Table Packaging</field>
            <field name="sequence">30</field>
            <field name="duration_minutes">20.0</field>
        </record>

        <!-- BoM for Office Chair -->
        <record id="bom_office_chair" model="mrp.bom">
            <field name="product_id" ref="product_office_chair"/>
            <field name="product_qty">1.0</field>
            <field name="notes">Ergonomic swivel office chair</field>
        </record>

        <!-- Components for Office Chair BoM -->
        <record id="bom_comp_chair_base" model="mrp.bom.component">
            <field name="bom_id" ref="bom_office_chair"/>
            <field name="product_id" ref="product_chair_base"/>
            <field name="quantity">1.0</field>
        </record>

        <record id="bom_comp_chair_wheels" model="mrp.bom.component">
            <field name="bom_id" ref="bom_office_chair"/>
            <field name="product_id" ref="product_wheels"/>
            <field name="quantity">5.0</field>
        </record>

        <record id="bom_comp_chair_screws" model="mrp.bom.component">
            <field name="bom_id" ref="bom_office_chair"/>
            <field name="product_id" ref="product_screws"/>
            <field name="quantity">8.0</field>
        </record>

        <!-- Operations for Office Chair BoM -->
        <record id="bom_op_chair_assembly" model="mrp.bom.operation">
            <field name="bom_id" ref="bom_office_chair"/>
            <field name="work_center_id" ref="wc_assembly"/>
            <field name="name">Chair Assembly</field>
            <field name="sequence">10</field>
            <field name="duration_minutes">45.0</field>
        </record>

        <record id="bom_op_chair_packing" model="mrp.bom.operation">
            <field name="bom_id" ref="bom_office_chair"/>
            <field name="work_center_id" ref="wc_packaging"/>
            <field name="name">Chair Packaging</field>
            <field name="sequence">20</field>
            <field name="duration_minutes">15.0</field>
        </record>

        <!-- Demo MO in Draft state for Wooden Table x10 -->
        <record id="mo_wooden_table_draft" model="mrp.production">
            <field name="product_id" ref="product_wooden_table"/>
            <field name="product_qty">10.0</field>
            <field name="bom_id" ref="bom_wooden_table"/>
            <field name="state">draft</field>
            <field name="date_planned_start" eval="datetime.now().strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="notes">Initial batch for showroom inventory</field>
        </record>
    </data>
</odoo>
