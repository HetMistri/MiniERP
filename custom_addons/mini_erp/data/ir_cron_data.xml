<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_procurement_reordering" model="ir.cron">
            <field name="name">Procurement: Run Scheduler (Daily Reordering)</field>
            <field name="model_id" ref="model_procurement_manager"/>
            <field name="state">code</field>
            <field name="code">model._cron_evaluate_reordering_rules()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
